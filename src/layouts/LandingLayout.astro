---
import '../styles/global.css';

interface Props {
	lang: 'en' | 'es';
	title: string;
	description: string;
	currentPath: string;
}

const { lang, title, description, currentPath } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const enHref = `${base}/`;
const esHref = `${base}/es`;
const docsHref = lang === 'es' ? `${base}/es/overview` : `${base}/overview`;
const githubHref = 'https://github.com/sgeraldes/avatardirector-docs';
const altLangHref = lang === 'es' ? enHref : esHref;
const altLangLabel = lang === 'es' ? 'EN' : 'ES';

const t = (en: string, es: string) => (lang === 'es' ? es : en);
---

<!doctype html>
<html lang={lang} data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
	</head>
	<body class="bg-ad-void text-white">
		<header class="sticky top-0 z-50 border-b border-white/[0.06] bg-ad-void/80 backdrop-blur-md">
			<div class="mx-auto flex h-16 max-w-[1280px] items-center justify-between px-6">
				<a href={lang === 'es' ? esHref : enHref} class="flex items-center gap-2.5" aria-label="AvatarDirector">
					<img src={`${base}/brand/ad-mark.svg`} alt="" height="26" style="height:26px;width:auto;" />
					<span class="ad-display text-base font-semibold tracking-[0.04em]">
						AVATAR<span class="ad-grad-text">DIRECTOR</span>
					</span>
				</a>
				<nav class="hidden items-center gap-7 text-sm text-ad-fog lg:flex">
					<a href={docsHref} class="transition-colors hover:text-white">{t('Overview', 'Introducción')}</a>
					<a href={`${docsHref.replace('/overview', '/protocol/tcp')}`} class="transition-colors hover:text-white">{t('Protocol', 'Protocolo')}</a>
					<a href={`${docsHref}#emotions`} class="transition-colors hover:text-white">{t('Emotions', 'Emociones')}</a>
					<a href={`${docsHref}#gestures`} class="transition-colors hover:text-white">{t('Gestures', 'Gestos')}</a>
					<a href={docsHref} class="transition-colors hover:text-white">Docs</a>
				</nav>
				<div class="flex items-center gap-3">
					<span class="ad-pill hidden md:inline-flex"><span class="dot"></span>v0.9.4</span>
					<a href={altLangHref} class="ad-pill" aria-label={t('Switch language', 'Cambiar idioma')}>
						<span class="text-xs font-semibold tracking-wider text-white">{altLangLabel}</span>
					</a>
					<a href={docsHref} class="ad-btn-primary text-sm" style="padding:8px 16px;font-size:13px;">
						{t('Read the docs', 'Ver la documentación')}
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
					</a>
				</div>
			</div>
		</header>

		<slot />

		<footer class="border-t border-white/[0.06] pt-16 pb-12">
			<div class="mx-auto grid max-w-[1280px] gap-10 px-6 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
				<div>
					<div class="flex items-center gap-2.5">
						<img src={`${base}/brand/ad-mark.svg`} alt="" style="height:26px;width:auto;" />
						<span class="ad-display text-base font-semibold tracking-[0.04em]">
							AVATAR<span class="ad-grad-text">DIRECTOR</span>
						</span>
					</div>
					<p class="mt-4 max-w-[320px] text-sm leading-relaxed text-ad-fog">
						{t(
							'An Unreal Engine plugin for real-time MetaHuman avatar control. Open source, MIT licensed.',
							'Un plugin de Unreal Engine para control de avatares MetaHuman en tiempo real. Open source, licencia MIT.'
						)}
					</p>
					<div class="mt-4 flex gap-2">
						<span class="ad-pill text-[11px]"><span class="dot"></span>v0.9.4</span>
						<span class="ad-pill text-[11px]" style="color:var(--ad-fog);">UE 5.7</span>
					</div>
				</div>
				<div>
					<div class="mb-3.5 text-[11px] font-semibold tracking-[0.12em] text-ad-fog uppercase">{t('Documentation', 'Documentación')}</div>
					<div class="flex flex-col gap-2.5 text-sm">
						<a href={docsHref} class="text-ad-fog transition-colors hover:text-white">{t('Getting started', 'Comenzar')}</a>
						<a href={`${docsHref.replace('/overview', '/protocol/tcp')}`} class="text-ad-fog transition-colors hover:text-white">{t('Protocol reference', 'Referencia del protocolo')}</a>
						<a href={`${docsHref.replace('/overview', '/protocol/session-lifecycle')}`} class="text-ad-fog transition-colors hover:text-white">{t('Lifecycle', 'Ciclo de vida')}</a>
						<a href={`${docsHref.replace('/overview', '/protocol/lipsync-settings')}`} class="text-ad-fog transition-colors hover:text-white">{t('Configuration', 'Configuración')}</a>
					</div>
				</div>
				<div>
					<div class="mb-3.5 text-[11px] font-semibold tracking-[0.12em] text-ad-fog uppercase">{t('System', 'Sistema')}</div>
					<div class="flex flex-col gap-2.5 text-sm">
						<a href={`${docsHref}#emotions`} class="text-ad-fog transition-colors hover:text-white">{t('Emotions', 'Emociones')}</a>
						<a href={`${docsHref}#microexpressions`} class="text-ad-fog transition-colors hover:text-white">{t('Microexpressions', 'Microexpresiones')}</a>
						<a href={`${docsHref}#gestures`} class="text-ad-fog transition-colors hover:text-white">{t('Gestures', 'Gestos')}</a>
						<a href={`${docsHref.replace('/overview', '/protocol/lipsync-settings')}`} class="text-ad-fog transition-colors hover:text-white">{t('Lip-sync', 'Lip-sync')}</a>
					</div>
				</div>
				<div>
					<div class="mb-3.5 text-[11px] font-semibold tracking-[0.12em] text-ad-fog uppercase">{t('Project', 'Proyecto')}</div>
					<div class="flex flex-col gap-2.5 text-sm">
						<a href={githubHref} class="text-ad-fog transition-colors hover:text-white">GitHub</a>
						<a href={`${docsHref.replace('/overview', '/releases/ls009')}`} class="text-ad-fog transition-colors hover:text-white">{t('Releases', 'Versiones')}</a>
						<a href={`${githubHref}/issues`} class="text-ad-fog transition-colors hover:text-white">Issues</a>
						<a href={`${githubHref}/blob/main/LICENSE`} class="text-ad-fog transition-colors hover:text-white">License</a>
					</div>
				</div>
			</div>
			<div class="mx-auto mt-12 flex max-w-[1280px] items-center justify-between border-t border-white/[0.06] px-6 pt-6 text-xs text-ad-fog">
				<span>© 2026 AvatarDirector contributors · MIT License</span>
				<span class="font-mono">Build · Apr 22 2026 01:13</span>
			</div>
		</footer>
	</body>
</html>
