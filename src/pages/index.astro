---
import LandingLayout from '../layouts/LandingLayout.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import ExpressionSystem from '../components/ExpressionSystem.astro';
import BodyGestures from '../components/BodyGestures.astro';
import DesignSystemStrip from '../components/DesignSystemStrip.astro';
---

<LandingLayout
	lang="en"
	title="AvatarDirector — Real-time avatar control for Unreal Engine 5.7"
	description="AvatarDirector drives a MetaHuman avatar in real time from an external backend, receiving commands and streaming PCM audio over a single TCP socket."
	currentPath="/"
>
	<Hero lang="en" />
	<FeatureGrid lang="en" />
	<HowItWorks lang="en" />
	<ExpressionSystem lang="en" />
	<BodyGestures lang="en" />
	<DesignSystemStrip lang="en" />
</LandingLayout>
