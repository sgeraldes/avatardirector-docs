---
interface Props {
	lang: 'en' | 'es';
}
const { lang } = Astro.props;
const t = (en: string, es: string) => (lang === 'es' ? es : en);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const docsHref = lang === 'es' ? `${base}/es/overview` : `${base}/overview`;
const githubHref = 'https://github.com/sgeraldes/avatardirector-docs';

const features = [
	{
		title: t('Real-time TCP communication', 'Comunicación TCP en tiempo real'),
		desc: t('Single socket for commands and PCM audio.', 'Un único socket para comandos y audio PCM.'),
		iconPath:
			'M8 8a4 4 0 1 1 8 0v2H8V8Zm-2 4h12a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2Zm6 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z',
	},
	{
		title: t('Advanced expression system', 'Sistema de expresiones avanzado'),
		desc: t('8 emotions × 22 microexpressions, sequenced through one state machine.', '8 emociones × 22 microexpresiones, secuenciadas por una máquina de estados.'),
		iconPath:
			'M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20Zm-3-9c0 1.7 1.3 3 3 3s3-1.3 3-3M9 9h.01M15 9h.01',
	},
	{
		title: t('Full-body communication', 'Comunicación corporal completa'),
		desc: t('Body gesture montages and gaze targeting driven by the same protocol.', 'Montages de gestos corporales y mirada controlados por el mismo protocolo.'),
		iconPath:
			'M12 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm-2 7v4l-3 9h2l2-6 1 6h2l1-6 2 6h2l-3-9V9h-6Z',
	},
	{
		title: t('Non-intrusive by design', 'No intrusivo por diseño'),
		desc: t('No modification to the MetaHuman face animation Blueprint.', 'Sin modificar el Blueprint de animación facial del MetaHuman.'),
		iconPath:
			'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Zm-1-12 2 2 4-4',
	},
];
---

<section class="relative overflow-hidden">
	<div class="absolute inset-0 bg-gradient-to-b from-ad-violet/[0.08] via-transparent to-transparent pointer-events-none"></div>
	<div class="absolute -top-32 -left-32 size-96 rounded-full bg-ad-violet/20 blur-[120px] pointer-events-none"></div>
	<div class="absolute -top-24 right-0 size-96 rounded-full bg-ad-cyan/20 blur-[120px] pointer-events-none"></div>

	<div class="relative mx-auto max-w-[1280px] px-6 py-16 md:py-24 lg:py-28">
		<div class="grid items-center gap-12 lg:grid-cols-[1.1fr_1fr]">
			<div>
				<div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-xs font-medium tracking-wider text-ad-fog uppercase">
					<span class="size-1.5 rounded-full bg-ad-mint"></span>
					{t('Unreal Engine 5.7 · Plugin', 'Unreal Engine 5.7 · Plugin')}
				</div>
				<h1 class="text-balance text-4xl font-bold leading-[1.05] tracking-tight md:text-5xl lg:text-6xl">
					{t('Real-time avatar control.', 'Control de avatares en tiempo real.')}<br />
					<span class="ad-grad-text">{t('Seamless performance.', 'Rendimiento sin fricción.')}</span>
				</h1>
				<p class="mt-6 max-w-xl text-lg leading-relaxed text-ad-fog">
					{t(
						'AvatarDirector is an Unreal Engine plugin that drives a MetaHuman avatar in real time from an external backend, receiving commands and streaming PCM audio over a single TCP socket.',
						'AvatarDirector es un plugin de Unreal Engine que controla un avatar MetaHuman en tiempo real desde un backend externo, recibiendo comandos y transmitiendo audio PCM por un único socket TCP.'
					)}
				</p>
				<div class="mt-8 flex flex-wrap items-center gap-3">
					<a href={docsHref} class="ad-btn-primary">
						{t('Read the docs', 'Ver la documentación')}
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
					</a>
					<a href={githubHref} class="ad-btn-secondary">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.13c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18A11 11 0 0 1 12 6.78c.99 0 1.99.13 2.93.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56 4.56-1.52 7.85-5.83 7.85-10.91C23.5 5.65 18.35.5 12 .5Z"/></svg>
						GitHub
					</a>
				</div>

				<dl class="mt-12 grid gap-4 sm:grid-cols-2">
					{features.map((f) => (
						<div class="flex items-start gap-3">
							<div class="mt-0.5 flex size-9 shrink-0 items-center justify-center rounded-lg border border-white/10 bg-white/[0.03] text-ad-cyan">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={f.iconPath}/></svg>
							</div>
							<div>
								<dt class="text-sm font-semibold text-white">{f.title}</dt>
								<dd class="mt-0.5 text-sm leading-snug text-ad-fog">{f.desc}</dd>
							</div>
						</div>
					))}
				</dl>
			</div>

			<div class="relative">
				<div class="relative overflow-hidden rounded-2xl border border-white/[0.08] bg-ad-ink shadow-[0_30px_80px_-20px_rgba(108,92,255,0.35)]">
					<img
						src={`${base}/avatar/hero.png`}
						alt={t('AvatarDirector avatar speaking, with audio waves visualizing speech', 'Avatar de AvatarDirector hablando, con ondas de audio visualizando la voz')}
						width="1536"
						height="1024"
						class="h-auto w-full"
						loading="eager"
						fetchpriority="high"
					/>
					<div class="absolute bottom-4 right-4 flex flex-col gap-2">
						<div class="flex items-center gap-2 rounded-lg border border-white/10 bg-ad-void/80 px-3 py-2 backdrop-blur-md">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-ad-cyan"><path d="M3 12h2l3-9 4 18 3-12 2 6h4"/></svg>
							<span class="text-[11px] font-semibold tracking-wider text-white uppercase">{t('PCM audio stream', 'Stream PCM')}</span>
						</div>
						<div class="flex items-center gap-2 rounded-lg border border-white/10 bg-ad-void/80 px-3 py-2 backdrop-blur-md">
							<span class="size-1.5 rounded-full bg-ad-mint"></span>
							<span class="text-[11px] font-semibold tracking-wider text-white uppercase">{t('Connected', 'Conectado')} · 4500</span>
						</div>
					</div>
				</div>
				<div class="mt-4 grid grid-cols-3 gap-3">
					<div class="ad-card px-4 py-3">
						<div class="text-[10px] font-medium tracking-wider text-ad-fog uppercase">{t('Engine', 'Motor')}</div>
						<div class="mt-1 text-sm font-semibold text-white">UE 5.7</div>
					</div>
					<div class="ad-card px-4 py-3">
						<div class="text-[10px] font-medium tracking-wider text-ad-fog uppercase">{t('Transport', 'Transporte')}</div>
						<div class="mt-1 text-sm font-semibold text-white">TCP · 4500</div>
					</div>
					<div class="ad-card px-4 py-3">
						<div class="text-[10px] font-medium tracking-wider text-ad-fog uppercase">{t('Audio', 'Audio')}</div>
						<div class="mt-1 text-sm font-semibold text-white">48 kHz · 16-bit</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
