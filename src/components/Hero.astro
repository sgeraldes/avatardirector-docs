---
interface Props {
	lang: 'en' | 'es';
}
const { lang } = Astro.props;
const t = (en: string, es: string) => (lang === 'es' ? es : en);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const docsHref = lang === 'es' ? `${base}/es/overview` : `${base}/overview`;
const protocolHref = lang === 'es' ? `${base}/es/protocol/tcp` : `${base}/protocol/tcp`;
const githubHref = 'https://github.com/sgeraldes/avatardirector-docs';

// Heights for the audio-bar visualizer overlay on the portrait card
const bars = [10, 18, 28, 22, 14, 9, 16, 30, 24, 12, 7, 14, 26, 22, 16, 10, 20, 28];

const stats: Array<[string, string]> = [
	['48 kHz', t('PCM in', 'PCM in')],
	['8 × 22', t('emotions × micro', 'emociones × micro')],
	['~100 ms', t('lookahead', 'lookahead')],
	['port 4500', t('single TCP', 'único TCP')],
];
---

<section class="relative overflow-hidden pt-20 pb-24">
	<!-- Ambient blurs -->
	<div aria-hidden class="pointer-events-none absolute -top-32 -left-24 h-[480px] w-[480px] rounded-full bg-ad-violet/[0.22] blur-[120px]"></div>
	<div aria-hidden class="pointer-events-none absolute -top-24 -right-24 h-[480px] w-[480px] rounded-full bg-ad-cyan/[0.22] blur-[120px]"></div>
	<div aria-hidden class="pointer-events-none absolute inset-0" style="background:linear-gradient(to bottom, rgba(108,92,255,0.06), transparent 60%);"></div>

	<div class="relative mx-auto grid max-w-[1280px] items-center gap-14 px-6 lg:grid-cols-[1.05fr_1fr]">
		<div>
			<img src={`${base}/brand/ad-lockup-horizontal-final-bg-stripped.png`}
			     alt="AvatarDirector — Real-time avatar control"
			     class="mb-8 block" style="height:140px;width:auto;max-width:100%;" />
			<div class="inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-ad-ink px-3 py-1.5">
				<span class="size-1.5 rounded-full bg-ad-cyan" style="box-shadow:0 0 8px var(--ad-cyan);"></span>
				<span class="text-xs text-white/80">{t('Unreal Engine 5.7 plugin · MetaHuman ready', 'Plugin de Unreal Engine 5.7 · MetaHuman ready')}</span>
			</div>
			<h1 class="ad-display mt-5 mb-4 text-balance text-white" style="font-size:clamp(40px,5.6vw,64px);line-height:1.05;letter-spacing:-0.01em;">
				{t('Real-time avatar control.', 'Control de avatares en tiempo real.')}<br />
				<span class="ad-grad-text">{t('Seamless performance.', 'Rendimiento sin fricción.')}</span>
			</h1>
			<p class="m-0 max-w-[540px] text-[17px] leading-[1.65] text-ad-fog">
				{t(
					'Drive a MetaHuman from any backend over a single TCP socket. PCM audio in, lip-sync, emotion, and full-body gestures out — sequenced through one deterministic state machine.',
					'Controla un MetaHuman desde cualquier backend por un único socket TCP. Entra audio PCM; salen lip-sync, emoción y gestos corporales — secuenciados por una máquina de estados determinista.'
				)}
			</p>
			<div class="mt-7 flex flex-wrap gap-3">
				<a href={protocolHref} class="ad-btn-primary">
					{t('Read the protocol', 'Ver el protocolo')}
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
				</a>
				<a href={githubHref} class="ad-btn-secondary">{t('Docs on GitHub', 'Docs en GitHub')}</a>
			</div>
			<div class="mt-9 flex flex-wrap gap-x-6 gap-y-4">
				{stats.map(([v, l]) => (
					<div>
						<div class="ad-display font-semibold text-white" style="font-size:22px;">{v}</div>
						<div class="mt-1 text-[11px] font-semibold tracking-[0.12em] text-ad-fog uppercase">{l}</div>
					</div>
				))}
			</div>
		</div>

		<!-- Hero portrait card -->
		<div class="relative overflow-hidden rounded-[20px] border border-white/[0.10] bg-ad-ink"
		     style="aspect-ratio:4/5;box-shadow:var(--ad-shadow-hero);">
			<img src={`${base}/avatar/hero.png`} alt={t('AvatarDirector MetaHuman portrait', 'Retrato MetaHuman de AvatarDirector')}
			     class="h-full w-full" style="object-fit:cover;" loading="eager" fetchpriority="high" />

			<!-- Top-left: Connected pill -->
			<div class="absolute left-3.5 top-3.5">
				<span class="ad-pill" style="background:rgba(15,18,25,0.7);backdrop-filter:blur(8px);">
					<span class="dot"></span> Connected · 4500
				</span>
			</div>
			<!-- Top-right: PCM stream pulsing -->
			<div class="absolute right-3.5 top-3.5">
				<span class="ad-pill is-info" style="background:rgba(15,18,25,0.7);backdrop-filter:blur(8px);">
					<span class="dot"></span> PCM stream · 48 kHz
				</span>
			</div>
			<!-- Bottom strip: Active emotion + audio bars -->
			<div class="absolute right-4 bottom-4 left-4 flex items-end justify-between">
				<div>
					<div class="text-[11px] font-semibold tracking-[0.12em] text-ad-fog uppercase">{t('Active emotion', 'Emoción activa')}</div>
					<div class="ad-display mt-1 font-semibold text-white" style="font-size:20px;">Joy · 0.78</div>
				</div>
				<div class="flex gap-1">
					{bars.map((h) => (
						<span class="block w-[3px] rounded-[2px]"
						      style={`height:${h}px;background:var(--ad-cyan);opacity:0.85;box-shadow:0 0 8px var(--ad-cyan);`}></span>
					))}
				</div>
			</div>
		</div>
	</div>
</section>
