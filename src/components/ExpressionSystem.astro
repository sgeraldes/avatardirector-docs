---
interface Props {
	lang: 'en' | 'es';
}
const { lang } = Astro.props;
const t = (en: string, es: string) => (lang === 'es' ? es : en);

const emotions = [
	{ key: 'neutral',  label: t('Neutral',  'Neutral'),  color: '#A1A6B2', value: 0.42 },
	{ key: 'joy',      label: t('Joy',      'Alegría'),  color: '#FFC857', value: 0.78 },
	{ key: 'sadness',  label: t('Sadness',  'Tristeza'), color: '#6C5CFF', value: 0.10 },
	{ key: 'anger',    label: t('Anger',    'Enojo'),    color: '#FF6B6B', value: 0.05 },
	{ key: 'fear',     label: t('Fear',     'Miedo'),    color: '#7AE582', value: 0.18 },
	{ key: 'surprise', label: t('Surprise', 'Sorpresa'), color: '#00D1FF', value: 0.55 },
	{ key: 'disgust',  label: t('Disgust',  'Disgusto'), color: '#9B7AFA', value: 0.02 },
	{ key: 'trust',    label: t('Trust',    'Confianza'),color: '#FF9560', value: 0.66 },
];
---

<section id="emotions" class="border-t border-white/[0.06] py-24" data-expression>
	<div class="mx-auto max-w-[1280px] px-6">
		<div class="grid items-center gap-14 lg:grid-cols-[1fr_1.1fr]">
			<div>
				<div class="text-[11px] font-semibold tracking-[0.12em] text-ad-cyan uppercase">{t('Expression system', 'Sistema de expresiones')}</div>
				<h2 class="ad-display mt-3 mb-3 text-white" style="font-size:36px;font-weight:700;">
					{t('8 emotions ×', '8 emociones ×')} <span class="ad-grad-text">{t('22 microexpressions.', '22 microexpresiones.')}</span>
				</h2>
				<p class="m-0 text-base leading-[1.65] text-ad-fog">
					{t(
						'Set primary emotion blends with intensity 0–1. Layer microexpressions on top — eye narrowing, lip tightening, brow raise, blink rate. The state machine handles cross-fades and recovery.',
						'Definí mezclas de emoción primaria con intensidad 0–1. Capa microexpresiones encima — entrecerrado de ojos, tensión de labios, ceja, parpadeo. La máquina de estados maneja cross-fades y recuperación.'
					)}
				</p>
				<div class="mt-7 grid grid-cols-2 gap-2">
					{emotions.map((e, i) => (
						<button type="button"
						        class="flex items-center justify-between rounded-[10px] border px-3.5 py-2.5 text-left transition-all"
						        data-emotion-btn={i}
						        style={`border-color:var(--ad-hairline);background:var(--ad-ink);`}>
							<span class="flex items-center gap-2.5">
								<span class="size-2.5 rounded-full" style={`background:${e.color};box-shadow:0 0 10px ${e.color}88;`}></span>
								<span class="text-sm font-medium text-white">{e.label}</span>
							</span>
							<span class="font-mono text-[11px] text-ad-fog">{e.value.toFixed(2)}</span>
						</button>
					))}
				</div>
			</div>

			<!-- Live blend visual -->
			<div class="ad-card p-7">
				<div class="mb-5 flex items-center justify-between">
					<div>
						<div class="text-[11px] font-semibold tracking-[0.12em] text-ad-fog uppercase">{t('Active blend', 'Mezcla activa')}</div>
						<div class="ad-display mt-1 font-extrabold text-white" style="font-size:26px;">
							<span data-active-label>{emotions[1].label}</span> · <span data-active-value style={`color:${emotions[1].color};`}>{emotions[1].value.toFixed(2)}</span>
						</div>
					</div>
					<span class="ad-pill is-info text-xs"><span class="dot"></span>{t('Cross-fade 240ms', 'Cross-fade 240ms')}</span>
				</div>

				<div class="mb-5 flex flex-col gap-2.5">
					{emotions.map((e, i) => (
						<div class="flex items-center gap-3" data-bar-row={i}>
							<span class="w-[70px] text-xs text-ad-fog" data-bar-label>{e.label}</span>
							<div class="h-1.5 flex-1 overflow-hidden rounded-full" style="background:rgba(255,255,255,0.05);">
								<div class="h-full transition-[width] duration-300"
								     style={`width:${e.value * 100}%;background:${e.color};box-shadow:0 0 8px ${e.color}55;`}></div>
							</div>
							<span class="w-10 text-right font-mono text-[11px] text-ad-fog">{e.value.toFixed(2)}</span>
						</div>
					))}
				</div>

				<!-- Microexpression dot grid (22) -->
				<div class="border-t border-white/[0.06] pt-4.5">
					<div class="mb-3 text-[11px] font-semibold tracking-[0.12em] text-ad-fog uppercase">{t('Microexpressions · 22 channels', 'Microexpresiones · 22 canales')}</div>
					<div class="flex flex-wrap gap-2" data-micro-grid>
						{Array.from({ length: 22 }).map((_, i) => (
							<span class="size-3 rounded-full" data-micro-dot={i}
							      style="background:rgba(255,255,255,0.06);box-shadow:inset 0 0 0 1px rgba(255,255,255,0.05);transition:background 0.15s;"></span>
						))}
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	[data-expression] [data-emotion-btn][aria-selected="true"] {
		background: var(--bg-elev-3, rgba(255,255,255,0.06)) !important;
	}
</style>

<script is:inline define:vars={{ emotions }}>
	(function () {
		const root = document.querySelector('[data-expression]');
		if (!root) return;
		const labelEl = root.querySelector('[data-active-label]');
		const valueEl = root.querySelector('[data-active-value]');
		const dots = root.querySelectorAll('[data-micro-dot]');
		const buttons = root.querySelectorAll('[data-emotion-btn]');
		let active = 1;

		function apply(i) {
			const e = emotions[i];
			labelEl.textContent = e.label;
			valueEl.textContent = e.value.toFixed(2);
			valueEl.style.color = e.color;
			dots.forEach((dot, idx) => {
				const lit = (idx * 7 + i * 3) % 22 < 9;
				dot.style.background = lit ? e.color : 'rgba(255,255,255,0.06)';
				dot.style.boxShadow = lit ? `0 0 10px ${e.color}66, inset 0 0 0 1px rgba(255,255,255,0.1)` : 'inset 0 0 0 1px rgba(255,255,255,0.05)';
			});
			buttons.forEach((b, idx) => {
				const sel = idx === i;
				b.setAttribute('aria-selected', sel ? 'true' : 'false');
				b.style.borderColor = sel ? e.color + '66' : 'var(--ad-hairline)';
			});
		}
		buttons.forEach((b, i) => b.addEventListener('click', () => { active = i; apply(i); }));
		apply(active);
	})();
</script>
