---
interface Props {
	lang: 'en' | 'es';
}
const { lang } = Astro.props;
const t = (en: string, es: string) => (lang === 'es' ? es : en);

const gestures = [
	'greet',
	'affirm',
	'deny',
	'point',
	'shrug',
	'open_arms',
	'cheer',
	'wave',
	'thinking_pose',
	'count_one',
	'count_two',
	'invite',
];
---

<section class="border-t border-white/[0.06] py-16 md:py-20">
	<div class="mx-auto max-w-[1280px] px-6">
		<div class="mb-10 max-w-3xl">
			<div class="text-xs font-semibold tracking-wider text-ad-cyan uppercase">{t('Body gestures', 'Gestos corporales')}</div>
			<h2 class="mt-2 text-3xl font-bold tracking-tight md:text-4xl">{t('Full-body montages, not just talking heads.', 'Montages de cuerpo completo, no sólo cabezas parlantes.')}</h2>
			<p class="mt-4 text-base leading-relaxed text-ad-fog">
				{t(
					'Gesture montages run on the body mesh, sequenced through the same state machine as speech and emotion. Triggered with one JSON command — name it and send it.',
					'Los montages de gestos corren en la malla del cuerpo, secuenciados por la misma máquina de estados que el habla y la emoción. Se disparan con un solo comando JSON — nómbralo y mandálo.'
				)}
			</p>
		</div>

		<div class="grid gap-4 lg:grid-cols-[1.2fr_1fr]">
			<div class="ad-card p-6">
				<div class="mb-4 flex items-center justify-between">
					<div class="text-[11px] font-semibold tracking-wider text-ad-fog uppercase">{t('Available gestures', 'Gestos disponibles')}</div>
					<div class="text-xs text-ad-fog">{t('extend at runtime via montage assets', 'extensible en runtime con montages')}</div>
				</div>
				<div class="flex flex-wrap gap-2">
					{gestures.map((g) => (
						<code class="rounded-md border border-white/10 bg-white/[0.03] px-2.5 py-1 font-mono text-sm text-white transition-colors hover:border-ad-cyan/50 hover:text-ad-cyan">{g}</code>
					))}
				</div>
			</div>

			<div class="ad-card overflow-hidden p-0">
				<div class="flex items-center justify-between border-b border-white/[0.06] px-5 py-3">
					<div class="text-[11px] font-semibold tracking-wider text-ad-fog uppercase">{t('Trigger any gesture', 'Disparar cualquier gesto')}</div>
					<span class="ad-pill is-info"><span class="dot"></span>JSON</span>
				</div>
				<pre class="overflow-x-auto p-5 text-sm leading-relaxed"><code class="font-mono text-ad-fog"><span class="text-ad-fog">{'{ '}</span><span class="text-ad-cyan">"type"</span><span class="text-ad-fog">: </span><span class="text-ad-mint">"anim_gesture"</span><span class="text-ad-fog">, </span><span class="text-ad-cyan">"name"</span><span class="text-ad-fog">: </span><span class="text-ad-mint">"greet"</span><span class="text-ad-fog">{' }'}</span></code></pre>
				<div class="border-t border-white/[0.06] px-5 py-3 text-xs leading-relaxed text-ad-fog">
					{t(
						'Replace ',
						'Reemplazá '
					)}<code class="rounded bg-white/[0.05] px-1 font-mono text-ad-cyan">"greet"</code>{t(
						' with any name from the list. Sent over the same TCP socket as audio and config.',
						' por cualquier nombre de la lista. Va por el mismo socket TCP que el audio y la config.'
					)}
				</div>
			</div>
		</div>
	</div>
</section>
