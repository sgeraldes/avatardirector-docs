---
interface Props {
	lang: 'en' | 'es';
}
const { lang } = Astro.props;
const t = (en: string, es: string) => (lang === 'es' ? es : en);

const gestures: Array<[string, string, string]> = [
	['greet',         t('Wave + slight bow',           'Saludo + leve reverencia'), '1.4s'],
	['affirm',        t('Single nod',                  'Asentimiento corto'),       '0.8s'],
	['deny',          t('Shake head, soft frown',      'Niega con leve ceño'),      '1.0s'],
	['point',         t('Index point + gaze track',    'Señalar + seguimiento'),    '1.2s'],
	['shrug',         t('Shoulders + palms-up',        'Hombros + palmas arriba'),  '1.6s'],
	['cheer',         t('Both arms raised',            'Ambos brazos arriba'),      '2.2s'],
	['wave',          t('Hand wave',                   'Saludo con la mano'),       '1.8s'],
	['thinking_pose', t('Hand to chin, gaze drift',    'Mano al mentón, mirada deriva'), '3.0s'],
];
---

<section id="gestures" class="border-t border-white/[0.06] py-24" data-bodygestures>
	<div class="mx-auto max-w-[1280px] px-6">
		<div class="text-[11px] font-semibold tracking-[0.12em] text-ad-cyan uppercase">{t('Body gestures', 'Gestos corporales')}</div>
		<h2 class="ad-display mt-3 mb-3 text-white" style="font-size:36px;font-weight:700;">
			{t('Full-body montages,', 'Montages de cuerpo completo,')} <span class="ad-grad-text">{t('not just talking heads.', 'no sólo cabezas parlantes.')}</span>
		</h2>
		<p class="m-0 mb-10 max-w-[640px] text-base leading-[1.65] text-ad-fog">
			{t(
				'Trigger named gestures by string. Sequence them, blend with talking-head animation, and override gaze targets mid-performance.',
				'Dispará gestos por nombre. Secuenciálos, mezclá con la animación de habla y sobrescribí targets de mirada en plena actuación.'
			)}
		</p>

		<div class="grid gap-7 lg:grid-cols-[1.4fr_1fr]">
			<!-- Code sample -->
			<div class="ad-card overflow-hidden">
				<div class="flex items-center justify-between border-b border-white/[0.06] px-5 py-3.5">
					<div class="flex gap-2">
						<span class="size-2.5 rounded-full" style="background:#FF6B6B;"></span>
						<span class="size-2.5 rounded-full" style="background:#FFC857;"></span>
						<span class="size-2.5 rounded-full" style="background:#7AE582;"></span>
					</div>
					<span class="font-mono text-[11px] text-ad-fog">cmd_gesture.json · Type 1</span>
				</div>
				<pre class="m-0 overflow-auto p-5.5 font-mono leading-[1.7] text-white/85" style="font-size:13px;background:transparent;border:none;"><span style="color:var(--ad-fog)">{'{\n  '}</span><span style="color:var(--ad-cyan)">"type"</span><span style="color:var(--ad-fog)">{'    : '}</span><span style="color:var(--ad-mint)">"gesture"</span><span style="color:var(--ad-fog)">{',\n  '}</span><span style="color:var(--ad-cyan)">"name"</span><span style="color:var(--ad-fog)">{'    : '}</span><span style="color:var(--ad-mint)">"<span data-gesture-name>greet</span>"</span><span style="color:var(--ad-fog)">{',\n  '}</span><span style="color:var(--ad-cyan)">"blend"</span><span style="color:var(--ad-fog)">{'   : '}</span><span style="color:var(--ad-amber)">0.85</span><span style="color:var(--ad-fog)">{',\n  '}</span><span style="color:var(--ad-cyan)">"gaze"</span><span style="color:var(--ad-fog)">{'    : '}</span><span style="color:var(--ad-mint)">"camera"</span><span style="color:var(--ad-fog)">{',\n  '}</span><span style="color:var(--ad-cyan)">"queue"</span><span style="color:var(--ad-fog)">{'   : '}</span><span style="color:var(--ad-amber)">true</span><span style="color:var(--ad-fog)">{'\n}'}</span></pre>
			</div>

			<!-- Gesture list -->
			<div class="ad-card overflow-hidden p-2">
				{gestures.map(([name, desc, dur], i) => (
					<button type="button"
					        class="flex w-full items-center justify-between border-0 px-3.5 py-3 text-left transition-colors"
					        data-gesture-btn={name}
					        style={`background:transparent;cursor:pointer;${i < gestures.length - 1 ? 'border-bottom:1px solid var(--ad-hairline);' : ''}`}>
						<div class="flex items-center gap-3.5">
							<code class="rounded-md border px-2.5 py-[3px] font-mono text-xs text-white transition-all"
							      data-gesture-chip
							      style="background:var(--bg-elev-2);border-color:var(--ad-hairline-white);">{name}</code>
							<span class="text-[13px] text-ad-fog">{desc}</span>
						</div>
						<span class="font-mono text-[11px] text-ad-fog">{dur}</span>
					</button>
				))}
			</div>
		</div>
	</div>
</section>

<script is:inline>
	(function () {
		const root = document.querySelector('[data-bodygestures]');
		if (!root) return;
		const nameEl = root.querySelector('[data-gesture-name]');
		const buttons = root.querySelectorAll('[data-gesture-btn]');
		buttons.forEach((b) => {
			const name = b.getAttribute('data-gesture-btn');
			const chip = b.querySelector('[data-gesture-chip]');
			b.addEventListener('mouseenter', () => {
				if (nameEl) nameEl.textContent = name;
				b.style.background = 'var(--bg-elev-3, rgba(255,255,255,0.06))';
				if (chip) {
					chip.style.borderColor = 'rgba(0,209,255,0.4)';
					chip.style.color = 'var(--ad-cyan)';
				}
			});
			b.addEventListener('mouseleave', () => {
				if (nameEl) nameEl.textContent = 'greet';
				b.style.background = 'transparent';
				if (chip) {
					chip.style.borderColor = 'var(--ad-hairline-white)';
					chip.style.color = '#fff';
				}
			});
		});
	})();
</script>
